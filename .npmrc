# Monorepo dev tooling (e.g. madge@8's peerOptional typescript ^5.4.4) declares
# peer ranges that predate the backend's TypeScript ~6.0.3. Those peers are
# optional and non-breaking, so installs use legacy peer resolution instead of
# failing. Keeps `npm install` reproducible for every developer, hook, and CI
# job without needing the --legacy-peer-deps flag each time.
legacy-peer-deps=true
