# Monorepo dev tooling (e.g. madge@8's peerOptional typescript ^5.4.4) declares
# peer ranges that predate the backend's TypeScript ~6.0.3. Those peers are
# optional and non-breaking, so installs use legacy peer resolution instead of
# failing. Keeps `npm install` reproducible for every developer, hook, and CI
# job without needing the --legacy-peer-deps flag each time.
legacy-peer-deps=true

# Deploy hosts (Vercel, Railway) run a production install — Vercel by default and
# Railway because NODE_ENV=production is set — which omits devDependencies. But the
# builds need dev-only tooling: `tsc7` (npm:typescript@7, aliased) compiles
# packages/shared, and `@nestjs/cli` builds apps/api. npm's rule is that a type in
# BOTH include and omit is included, so this forces devDependencies to install even
# under `--omit=dev`/`NODE_ENV=production`, without touching runtime NODE_ENV. Only
# affects what gets installed; it never changes runtime behavior.
include=dev
