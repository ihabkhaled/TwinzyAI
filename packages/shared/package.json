{
  "name": "@twinzy/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared constants, types, enums, interfaces, schemas, and utils for Twinzy.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../node_modules/tsc7/bin/tsc -p tsconfig.build.json",
    "typecheck": "node ../../node_modules/tsc7/bin/tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
