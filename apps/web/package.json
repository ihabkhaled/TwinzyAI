{
  "name": "@twinzy/web",
  "version": "0.1.0",
  "private": true,
  "description": "Twinzy frontend (Next.js App Router, mobile-first PWA).",
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "dev:turbo": "next dev --port 3000",
    "dev:e2e": "next dev --turbopack --port 3100",
    "build": "next build --turbopack",
    "build:turbo": "next build",
    "start": "next start --port 3000",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium --project=a11y --project=mobile-chromium"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@twinzy/shared": "*",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-intl": "^4.13.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-virtuoso": "^4.18.10",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2"
  }
}
