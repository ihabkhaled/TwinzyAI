{
  "name": "twinzy",
  "version": "0.1.0",
  "private": true,
  "description": "Twinzy — a free, privacy-safe, mobile-first AI style/vibe game.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "@nestjs/platform-fastify": {
      "fastify": "$fastify"
    },
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "workspaces": [
    "packages/tsconfig",
    "packages/eslint-config",
    "packages/shared",
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run build:shared && concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "build": "npm run build:shared && npm run build:api && npm run build:web",
    "build:shared": "npm run build --workspace packages/shared",
    "build:web": "npm run build --workspace apps/web",
    "build:api": "npm run build --workspace apps/api",
    "start": "concurrently -n api,web -c blue,green \"npm:start --workspace apps/api\" \"npm:start --workspace apps/web\"",
    "lint": "npm run build:shared && eslint . --concurrency 10",
    "lint:fix": "npm run build:shared && eslint . --concurrency 10 --fix",
    "typecheck": "npm run build:shared && npm run typecheck --workspaces --if-present",
    "test": "npm run build:shared && vitest run",
    "test:watch": "vitest",
    "test:unit": "npm run build:shared && vitest run --project api-unit --project web-unit --project shared-unit --project lint-rules",
    "test:integration": "npm run build:shared && vitest run --project api-integration",
    "test:e2e": "npm run test:e2e --workspace apps/web",
    "test:coverage": "npm run build:shared && vitest run --coverage",
    "test:security": "npm run build:shared && vitest run --project api-unit --project api-integration -- modules/file-security modules/privacy common",
    "test:file-security": "npm run build:shared && vitest run --project api-unit --project api-integration -- modules/file-security",
    "test:ai": "npm run build:shared && vitest run --project api-unit --project api-integration -- modules/ai modules/game modules/result-aggregation",
    "test:pwa": "npm run build:shared && vitest run --project web-unit -- pwa",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:rebuild": "docker compose build --no-cache",
    "validate": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "audit": "npm audit --omit dev",
    "security:scan": "trivy fs --scanners vuln,secret,misconfig --include-dev-deps --skip-dirs \"node_modules,**/node_modules,dist,**/dist,coverage,**/coverage,.next,**/.next,**/playwright-report,**/test-results\" --exit-code 1 --severity HIGH,CRITICAL .",
    "security:scan:secrets": "node scripts/scan-secrets.mjs",
    "security:scan:full": "trivy fs --scanners vuln,secret,misconfig --include-dev-deps --skip-dirs \"node_modules,**/node_modules,dist,**/dist,coverage,**/coverage,.next,**/.next,**/playwright-report,**/test-results\" .",
    "deps:check": "npm-check-updates --workspaces --root",
    "deps:upgrade": "npm-check-updates --workspaces --root -u && npm install",
    "quality:dead-code": "knip",
    "quality:circular": "madge apps/web/src apps/api/src --circular --extensions ts,tsx",
    "test:a11y": "npm run test:e2e --workspace apps/web -- --project=a11y --pass-with-no-tests",
    "test:visual": "npm run test:e2e --workspace apps/web -- --project=visual --pass-with-no-tests",
    "quality:frontend": "npm run lint && npm run typecheck && npm run test:e2e"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.5.0",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.10",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@typescript/native-preview": "^7.0.0-dev.20260705.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.21",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "lint-staged": "^16.1.0",
    "madge": "^8.0.0",
    "npm-check-updates": "^22.2.9",
    "prettier": "^3.6.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "fastify": "^5.10.0"
  }
}
