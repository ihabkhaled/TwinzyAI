{
  "name": "twinzy",
  "version": "0.1.0",
  "private": true,
  "description": "Twinzy — a free, privacy-safe, mobile-first AI style/vibe game.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.20 <23"
  },
  "overrides": {
    "@nestjs/platform-fastify": {
      "fastify": "$fastify"
    },
    "next": {
      "postcss": "^8.5.10"
    },
    "eslint-plugin-react": {
      "eslint": "$eslint"
    },
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  },
  "workspaces": [
    "packages/tsconfig",
    "packages/eslint-config",
    "packages/shared",
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run build:shared && concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "build": "npm run build:shared && npm run build:api && npm run build:web",
    "build:shared": "npm run build --workspace packages/shared",
    "build:web": "npm run build --workspace apps/web",
    "build:api": "npm run build --workspace apps/api",
    "start": "concurrently -n api,web -c blue,green \"npm:start --workspace apps/api\" \"npm:start --workspace apps/web\"",
    "lint": "npm run build:shared && eslint . --concurrency 10 --max-warnings 0",
    "lint:fix": "npm run build:shared && eslint . --concurrency 10 --max-warnings 0 --fix",
    "typecheck": "npm run build:shared && node node_modules/tsc7/bin/tsc --noEmit -p tsconfig.json && npm run typecheck --workspaces --if-present",
    "test": "npm run build:shared && vitest run",
    "test:watch": "vitest",
    "test:unit": "npm run build:shared && vitest run --project api-unit --project web-unit --project shared-unit --project lint-rules",
    "test:integration": "npm run build:shared && vitest run --project api-integration",
    "test:e2e": "npm run test:e2e --workspace apps/web",
    "test:e2e:ci": "npm run build:shared && npm run test:e2e:ci --workspace apps/web",
    "test:coverage": "npm run build:shared && vitest run --coverage",
    "test:security": "npm run build:shared && vitest run --project api-unit --project api-integration -- modules/file-security modules/privacy common",
    "test:file-security": "npm run build:shared && vitest run --project api-unit --project api-integration -- modules/file-security",
    "test:ai": "npm run build:shared && vitest run --project api-unit --project api-integration -- modules/ai modules/game modules/result-aggregation",
    "test:pwa": "npm run build:shared && vitest run --project web-unit -- pwa",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "node .husky/install.mjs",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:rebuild": "docker compose build --no-cache",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run quality:dead-code && npm run quality:circular",
    "audit": "npm audit --audit-level=low",
    "security:scan": "trivy fs --scanners vuln,secret,misconfig --include-dev-deps --skip-dirs \"node_modules,**/node_modules,dist,**/dist,coverage,**/coverage,.next,**/.next,**/playwright-report,**/test-results\" --exit-code 1 --severity HIGH,CRITICAL .",
    "security:audit": "npm audit --audit-level=low",
    "security:scan:images": "trivy image --exit-code 1 --severity HIGH,CRITICAL twinzy-api:local && trivy image --exit-code 1 --severity HIGH,CRITICAL twinzy-web:local",
    "security:scan:secrets": "node scripts/scan-secrets.mjs",
    "security:scan:full": "trivy fs --scanners vuln,secret,misconfig --include-dev-deps --skip-dirs \"node_modules,**/node_modules,dist,**/dist,coverage,**/coverage,.next,**/.next,**/playwright-report,**/test-results\" .",
    "deps:check": "npm-check-updates --workspaces --root",
    "deps:upgrade": "npm-check-updates --workspaces --root -u && npm install",
    "quality:dead-code": "knip",
    "quality:circular": "madge apps/web/src apps/api/src --circular --extensions ts,tsx",
    "load-test": "node scripts/load-test.mjs",
    "ai:benchmark": "npm run build --workspace apps/api && node apps/api/dist/benchmark/benchmark.main.js",
    "calibrate": "npm run build:shared && node scripts/calibrate.mjs",
    "test:a11y": "npm run test:a11y --workspace apps/web -- --pass-with-no-tests",
    "test:visual": "npm run test:visual --workspace apps/web -- --pass-with-no-tests",
    "quality:frontend": "npm run lint && npm run typecheck && npm run test:e2e",
    "knowledge:build": "node scripts/knowledge/build.mjs",
    "knowledge:build:incremental": "node scripts/knowledge/build-incremental.mjs",
    "knowledge:context": "node scripts/knowledge/resolve-context.mjs",
    "knowledge:classify": "node scripts/knowledge/classify-task.mjs",
    "knowledge:validate": "node scripts/knowledge/validate-frontmatter.mjs && node scripts/knowledge/validate-links.mjs && node scripts/knowledge/validate-source-references.mjs && node scripts/knowledge/validate-generated-files.mjs && node scripts/knowledge/validate-context-packs.mjs && node scripts/knowledge/find-contradictions.mjs",
    "knowledge:links": "node scripts/knowledge/validate-links.mjs",
    "knowledge:stale": "node scripts/knowledge/find-stale-items.mjs",
    "knowledge:contradictions": "node scripts/knowledge/find-contradictions.mjs",
    "knowledge:duplicates": "node scripts/knowledge/find-duplicates.mjs",
    "knowledge:orphans": "node scripts/knowledge/find-orphans.mjs",
    "knowledge:graphs": "node scripts/knowledge/build-graphs.mjs",
    "knowledge:packs": "node scripts/knowledge/build-packs.mjs",
    "knowledge:benchmark": "node scripts/knowledge/benchmark-context.mjs",
    "knowledge:report": "node scripts/knowledge/report.mjs",
    "knowledge:refresh": "node scripts/knowledge/build.mjs && node scripts/knowledge/report.mjs",
    "knowledge:tokens": "node scripts/knowledge/estimate-tokens.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.22",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.10.5",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^71.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "knip": "^6.25.0",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "npm-check-updates": "^22.2.9",
    "prettier": "^3.9.5",
    "tsc7": "npm:typescript@^7.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10",
    "yaml": "^2.8.1"
  },
  "dependencies": {
    "fastify": "^5.10.0"
  }
}
