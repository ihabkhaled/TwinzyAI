{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["trivy"],
  "ignoreDependencies": [
    "@nestjs/schematics",
    "@typescript-eslint/parser",
    "unplugin-swc",
    "@fastify/cors",
    "pino-pretty",
    "jsdom",
    "tailwindcss",
    "fastify"
  ],
  "ignoreUnresolved": ["src/tests/setup.ts"],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "optionalPeerDependencies": "error",
    "exports": "error",
    "nsExports": "error",
    "types": "error",
    "nsTypes": "error",
    "enumMembers": "error",
    "duplicates": "error"
  },
  "workspaces": {
    ".": {
      "project": ["eslint/**/*.mjs", "scripts/**/*.mjs", "*.{ts,mjs,cjs}"]
    },
    "apps/api": {
      "entry": [
        "src/main.ts",
        "src/**/*.test.ts",
        "src/**/*.integration.test.ts",
        "src/tests/**/*.ts",
        "src/benchmark/benchmark.main.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "apps/web": {
      "entry": [
        "e2e/**/*.spec.ts",
        "e2e/helpers.ts",
        "src/**/*.test.{ts,tsx}",
        "src/tests/**/*.{ts,tsx}",
        "src/packages/i18n/request.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/shared": {
      "entry": ["src/index.ts", "tests/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
