# --- Runtime ---
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000

# --- Logging ---
# One of: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- API docs ---
# Swagger UI at /docs. Defaults to enabled everywhere except production.
ENABLE_SWAGGER=true

# --- Rate limiting ---
# Global limit: RATE_LIMIT_MAX requests per RATE_LIMIT_TTL_MS window per client.
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=30

# --- CORS ---
# Comma-separated list of allowed web origins for the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Gemini (backend only — NEVER expose to the frontend) ---
GEMINI_API_KEY=
# Model id is loaded from env. Never hardcoded. Example: gemini-2.5-flash
GEMINI_MODEL=
GEMINI_TIMEOUT_MS=30000

# --- Upload limits ---
MAX_IMAGE_SIZE_BYTES=5242880

# --- Optional virus scanning ---
# When true in production, a failing/unreachable ClamAV fails CLOSED (uploads rejected).
ENABLE_CLAMAV=false
# Primary clamd host. The adapter falls back automatically between the `clamav`
# docker service name and 127.0.0.1, so the same value works whether the API runs
# inside docker-compose or on your host (`npm run dev`) against a ClamAV container
# started with: docker compose --profile clamav up -d clamav  (publishes 3310).
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# --- Frontend (public, safe values only) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
