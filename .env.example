# --- Runtime ---
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000

# --- Logging ---
# One of: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- API docs ---
# Swagger UI at /docs. Defaults to enabled everywhere except production.
ENABLE_SWAGGER=true

# --- Rate limiting ---
# Global limit: RATE_LIMIT_MAX requests per RATE_LIMIT_TTL_MS window per client.
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=30

# --- CORS ---
# Comma-separated list of allowed web origins for the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Gemini (backend only — NEVER expose to the frontend) ---
GEMINI_API_KEY=
# Model id is loaded from env. Never hardcoded. Example: gemini-2.5-flash
GEMINI_MODEL=gemini-3.5-flash
# Comma-separated ordered fallback models. On a 429/overload/unavailable the same
# call is retried down this list (starting at the primary above) before failing —
# each model has its own quota, so this survives a single model's limit. Leave
# blank to disable fallback. Use ids your API key can actually reach: note
# gemini-3-flash does NOT exist — the id is gemini-3-flash-preview.
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-3-flash-preview,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite
# Total deadline for a single non-streaming Gemini call.
GEMINI_TIMEOUT_MS=30000
# Idle (inter-chunk) timeout for STREAMING calls: the stream is aborted only
# after this long with no new token, so a long generation is never cut off
# while the model is still producing. Used by the /game/analyze/stream route.
GEMINI_STREAM_IDLE_TIMEOUT_MS=60000

# --- Upload limits ---
MAX_IMAGE_SIZE_BYTES=5242880

# --- Optional virus scanning ---
# When true in production, a failing/unreachable ClamAV fails CLOSED (uploads rejected).
ENABLE_CLAMAV=false
# Comma-separated ordered clamd hosts. The adapter tries each in turn and caches
# the first reachable one, so the same value works whether the API runs inside
# docker-compose (`clamav`) or on your host (`127.0.0.1`) against a ClamAV
# container started with: docker compose --profile clamav up -d clamav (port 3310).
CLAMAV_HOSTS=127.0.0.1,clamav
CLAMAV_PORT=3310

# --- Streaming concurrency / overload protection ---
# Hard caps on concurrent streaming analyses. Over-capacity runs queue up to
# MAX_ANALYSIS_QUEUE_SIZE, then are rejected in-band with SERVER_BUSY so a burst
# can never exhaust memory or the model quota.
MAX_GLOBAL_ACTIVE_ANALYSES=50
MAX_ACTIVE_ANALYSES_PER_IP=3
# One active analysis per browser tab (the client aborts a prior run before
# starting a new one); a spamming tab is queued then rejected.
MAX_ACTIVE_ANALYSES_PER_TAB=1
MAX_ANALYSIS_QUEUE_SIZE=100
# Watchdog: an analysis (and a queued waiter) is aborted after this long so a
# stuck provider call never holds a slot forever.
ANALYSIS_TIMEOUT_MS=120000
# Safety-net TTL for orphaned stream-registry entries. Keep above
# ANALYSIS_TIMEOUT_MS so healthy runs always finish before reclamation.
STREAM_TTL_MS=180000

# --- Frontend (public, safe values only) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
